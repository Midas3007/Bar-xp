# ============================================================================
#  bar-xp wallet consolidation — environment config
#  Copy to `.env` (which is gitignored) and fill in. NEVER commit real keys.
# ============================================================================

# --- Destination -------------------------------------------------------------
# The single wallet everything gets swept INTO.
DESTINATION_ADDRESS=0xYourMainWalletAddressHere

# --- Source wallets ----------------------------------------------------------
# Private keys of the wallets you want to drain, comma-separated.
# These are wallets YOU control. Each 0x-prefixed 64-hex-char key.
PRIVATE_KEYS=0xkey1,0xkey2,0xkey3

# --- Chains to sweep ---------------------------------------------------------
# Comma-separated chain keys. See src/chains.ts for the full list.
# Defaults to all configured chains if left unset.
CHAINS=ethereum,base,arbitrum,optimism,polygon,bnb

# --- RPC endpoints (optional overrides) --------------------------------------
# Sensible public defaults are built in, but they rate-limit. For real use,
# set your own per-chain RPC URL as RPC_<CHAINKEY> (uppercased).
# RPC_ETHEREUM=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
# RPC_BASE=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY
# RPC_ARBITRUM=https://arb-mainnet.g.alchemy.com/v2/YOUR_KEY

# --- Token discovery (optional) ----------------------------------------------
# Without an indexer, a wallet's ERC-20 holdings can't be enumerated from the
# chain alone. Two ways to tell the tool which tokens to look for:
#   1. An Alchemy API key -> auto-discovers all ERC-20 balances per wallet.
#   2. A tokens.json file listing token contract addresses per chain.
# You can use either or both. If neither is set, only native gas is swept.
ALCHEMY_API_KEY=

# --- Sweep behavior ----------------------------------------------------------
# Native gas token left behind in each source wallet (as a decimal amount of
# the native token, e.g. 0.0005 ETH). Prevents "insufficient funds for gas".
NATIVE_GAS_RESERVE=0.0005

# Skip token balances whose USD-agnostic raw value rounds to ~0. Set a minimum
# whole-token amount to bother transferring (e.g. 0.000001). Set 0 to move all.
MIN_TOKEN_AMOUNT=0

# Also sweep the leftover native token after ERC-20 transfers? (true/false)
SWEEP_NATIVE=true
